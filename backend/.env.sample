PORT=""
NODE_ENV=development
MONGO_URI=""

JWT_SECRET="your_jwt_secret"
JWT_REFRESH_SECRET="your_refresh_secret"
JWT_ACCESS_EXPIRES_IN=""
JWT_REFRESH_EXPIRES_IN=""

# AI via OpenRouter (https://openrouter.ai) — set OPENROUTER_API_KEY in .env (never commit real keys)
OPENROUTER_API_KEY=""
# e.g. qwen/qwen3.6-plus:free
OPENROUTER_MODEL="qwen/qwen3.6-plus:free"
# Optional headers for OpenRouter app listings
OPENROUTER_HTTP_REFERER=""
OPENROUTER_X_TITLE="AcadBuddy"

CLOUDINARY_API_SECRET=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_URL=""

# Public URLs (deploy)
BACKEND_URL=""
# CORS: your Vercel URL(s), no trailing slash. Also accepts CLIENT_URL or comma-separated FRONTEND_URLS.
FRONTEND_URL=""
CLIENT_URL=""
# FRONTEND_URLS="https://app.vercel.app,https://www.yourdomain.com"
